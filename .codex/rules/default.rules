# Destructive command guardrails for Codex.
#
# These rules replace the old per-command Python hook. Keep them
# focused on clear destructive prefixes so normal shell commands do not pay hook
# subprocess overhead.

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Recursive force deletion is blocked by repo policy. Use a scoped non-force command or ask the user for an explicit cleanup plan.",
    match = [
        "rm -rf build",
        "rm -rf /tmp/gantry-test",
    ],
    not_match = [
        "rm -r build",
        "rm file.txt",
    ],
)

prefix_rule(
    pattern = ["rm", "-fr"],
    decision = "forbidden",
    justification = "Recursive force deletion is blocked by repo policy. Use a scoped non-force command or ask the user for an explicit cleanup plan.",
    match = [
        "rm -fr build",
    ],
    not_match = [
        "rm -f file.txt",
    ],
)

prefix_rule(
    pattern = ["rm", ["-r", "-f", "--recursive", "--force"]],
    decision = "prompt",
    justification = "rm recursive/force flag variants can become destructive when combined. Use a scoped command or ask for explicit approval.",
    match = [
        "rm -r -f build",
        "rm --recursive --force build",
        "rm -f -r build",
    ],
    not_match = [
        "rm file.txt",
    ],
)

prefix_rule(
    pattern = [["PATH=/usr/bin", "PATH=/bin", "FOO=bar", "GIT_DIR=.git", "GIT_WORK_TREE=."], ["rm", "git", "terraform", "kubectl"]],
    decision = "prompt",
    justification = "Assignment-prefixed direct exec invocations can hide protected command prefixes. Run without inline assignments or ask for explicit approval.",
    match = [
        "PATH=/usr/bin git reset --hard",
        "FOO=bar rm -rf build",
        "GIT_DIR=.git git push origin feature --force",
    ],
    not_match = [
        "git status",
    ],
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Hard resets can discard user work. Inspect status and ask for explicit user approval before any destructive reset.",
    match = [
        "git reset --hard",
        "git reset --hard HEAD~1",
    ],
    not_match = [
        "git reset --soft HEAD~1",
        "git status",
    ],
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Git push may rewrite shared history when force flags appear after refspecs. Use the GitHub/ship workflow or ask for explicit approval before pushing.",
    match = [
        "git push origin feature",
        "git push origin feature --force-with-lease",
    ],
    not_match = [
        "git status",
        "git fetch origin",
    ],
)

prefix_rule(
    pattern = ["git", ["-c", "-C", "--git-dir", "--work-tree"]],
    decision = "prompt",
    justification = "Git global options can hide the eventual subcommand from prefix-only policy. Run the command without global indirection or ask for explicit approval.",
    match = [
        "git -C /tmp/repo push origin feature --force-with-lease",
        "git -c core.sshCommand=ssh push origin feature --force",
    ],
    not_match = [
        "git status",
        "git push origin feature",
    ],
)

prefix_rule(
    pattern = ["git", ["--no-pager", "--git-dir=.git", "--work-tree=.", "--bare"]],
    decision = "prompt",
    justification = "Git global options can hide the eventual subcommand from prefix-only policy. Run the command without global indirection or ask for explicit approval.",
    match = [
        "git --no-pager push origin feature --force",
        "git --git-dir=.git push origin feature --force-with-lease",
    ],
    not_match = [
        "git status",
        "git push origin feature",
    ],
)

prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "Force pushes can rewrite shared history. Ask for explicit user approval and use a narrowly scoped command.",
    match = [
        "git push --force",
        "git push --force origin feature",
    ],
    not_match = [
        "git push origin feature",
    ],
)

prefix_rule(
    pattern = ["git", "push", "-f"],
    decision = "forbidden",
    justification = "Force pushes can rewrite shared history. Ask for explicit user approval and use a narrowly scoped command.",
    match = [
        "git push -f",
        "git push -f origin feature",
    ],
    not_match = [
        "git push origin feature",
    ],
)

prefix_rule(
    pattern = ["git", "push", "--force-with-lease"],
    decision = "forbidden",
    justification = "Force-with-lease still rewrites shared history. Ask for explicit user approval and use a narrowly scoped command.",
    match = [
        "git push --force-with-lease",
        "git push --force-with-lease origin feature",
    ],
    not_match = [
        "git push origin feature",
    ],
)

prefix_rule(
    pattern = ["sudo"],
    decision = "forbidden",
    justification = "Privilege escalation can bypass command-specific safeguards. Ask the user for an explicit operator workflow instead.",
    match = [
        "sudo rm -rf /tmp/gantry-test",
        "sudo git reset --hard",
    ],
    not_match = [
        "git status",
    ],
)

prefix_rule(
    pattern = ["env"],
    decision = "prompt",
    justification = "env can hide command prefixes with assignments or path lookup. Run the command directly or ask for explicit approval.",
    match = [
        "env FOO=bar git push origin feature --force-with-lease",
        "env npm test",
    ],
    not_match = [
        "npm test",
    ],
)

prefix_rule(
    pattern = [["env", "/usr/bin/env"], ["-i", "--ignore-environment"], "rm", ["-rf", "-fr"]],
    decision = "forbidden",
    justification = "env option wrappers cannot be used to bypass recursive force deletion guardrails.",
    match = [
        "env -i rm -rf build",
        "/usr/bin/env --ignore-environment rm -fr build",
    ],
    not_match = [
        "env -i npm test",
    ],
)

prefix_rule(
    pattern = [["env", "/usr/bin/env"], ["-i", "--ignore-environment"], "git", "reset", "--hard"],
    decision = "forbidden",
    justification = "env option wrappers cannot be used to bypass hard reset guardrails.",
    match = [
        "env -i git reset --hard",
        "/usr/bin/env --ignore-environment git reset --hard",
    ],
    not_match = [
        "env -i git status",
    ],
)

prefix_rule(
    pattern = [["env", "/usr/bin/env"], ["-i", "--ignore-environment"], "git", "push"],
    decision = "prompt",
    justification = "env option wrappers can hide late git push force flags. Ask for explicit approval before pushing through env.",
    match = [
        "env -i git push origin feature --force-with-lease",
        "/usr/bin/env --ignore-environment git push origin feature --force",
    ],
    not_match = [
        "git status",
    ],
)

prefix_rule(
    pattern = [["env", "/usr/bin/env"], ["-i", "--ignore-environment"], "terraform", "destroy"],
    decision = "forbidden",
    justification = "env option wrappers cannot be used to bypass infrastructure destruction guardrails.",
    match = [
        "env -i terraform destroy",
        "/usr/bin/env --ignore-environment terraform destroy",
    ],
    not_match = [
        "env -i terraform plan",
    ],
)

prefix_rule(
    pattern = [["env", "/usr/bin/env"], ["-i", "--ignore-environment"], "kubectl", "delete"],
    decision = "forbidden",
    justification = "env option wrappers cannot be used to bypass Kubernetes deletion guardrails.",
    match = [
        "env -i kubectl delete namespace prod",
        "/usr/bin/env --ignore-environment kubectl delete pod api-123",
    ],
    not_match = [
        "env -i kubectl get pods",
    ],
)

prefix_rule(
    pattern = ["env", "rm", "-rf"],
    decision = "forbidden",
    justification = "Wrapper-prefixed recursive force deletion is blocked by repo policy.",
    match = [
        "env rm -rf build",
    ],
    not_match = [
        "env npm test",
    ],
)

prefix_rule(
    pattern = ["env", "rm", "-fr"],
    decision = "forbidden",
    justification = "Wrapper-prefixed recursive force deletion is blocked by repo policy.",
    match = [
        "env rm -fr build",
    ],
    not_match = [
        "env npm test",
    ],
)

prefix_rule(
    pattern = ["env", "git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Wrapper-prefixed hard resets can discard user work.",
    match = [
        "env git reset --hard",
    ],
    not_match = [
        "env git status",
    ],
)

prefix_rule(
    pattern = ["env", "git", "push", "--force"],
    decision = "forbidden",
    justification = "Wrapper-prefixed force pushes can rewrite shared history.",
    match = [
        "env git push --force",
    ],
    not_match = [
        "env git push origin feature",
    ],
)

prefix_rule(
    pattern = ["env", "git", "push", "-f"],
    decision = "forbidden",
    justification = "Wrapper-prefixed force pushes can rewrite shared history.",
    match = [
        "env git push -f",
    ],
    not_match = [
        "env git push origin feature",
    ],
)

prefix_rule(
    pattern = ["env", "git", "push", "--force-with-lease"],
    decision = "forbidden",
    justification = "Wrapper-prefixed force-with-lease still rewrites shared history.",
    match = [
        "env git push --force-with-lease",
    ],
    not_match = [
        "env git push origin feature",
    ],
)

prefix_rule(
    pattern = ["/usr/bin/env"],
    decision = "prompt",
    justification = "Absolute env can hide command prefixes with assignments or path lookup. Run the command directly or ask for explicit approval.",
    match = [
        "/usr/bin/env FOO=bar git push origin feature --force-with-lease",
        "/usr/bin/env npm test",
    ],
    not_match = [
        "npm test",
    ],
)

prefix_rule(
    pattern = ["/usr/bin/env", "rm", ["-rf", "-fr"]],
    decision = "forbidden",
    justification = "Absolute env cannot be used to bypass recursive force deletion guardrails.",
    match = [
        "/usr/bin/env rm -rf build",
        "/usr/bin/env rm -fr build",
    ],
    not_match = [
        "/usr/bin/env npm test",
    ],
)

prefix_rule(
    pattern = ["/usr/bin/env", "rm", ["-r", "-f", "--recursive", "--force"]],
    decision = "prompt",
    justification = "Absolute env cannot be used to bypass rm recursive/force guardrails.",
    match = [
        "/usr/bin/env rm -r -f build",
        "/usr/bin/env rm --recursive --force build",
    ],
    not_match = [
        "/usr/bin/env npm test",
    ],
)

prefix_rule(
    pattern = ["/usr/bin/env", "git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Absolute env cannot be used to bypass hard reset guardrails.",
    match = [
        "/usr/bin/env git reset --hard",
    ],
    not_match = [
        "/usr/bin/env git status",
    ],
)

prefix_rule(
    pattern = ["/usr/bin/env", "git", "push"],
    decision = "prompt",
    justification = "Absolute env can hide late git push force flags from fixed-prefix rules. Ask for explicit approval before pushing through env.",
    match = [
        "/usr/bin/env git push origin feature",
        "/usr/bin/env git push origin feature --force-with-lease",
    ],
    not_match = [
        "git status",
    ],
)

prefix_rule(
    pattern = ["/usr/bin/env", "terraform", "destroy"],
    decision = "forbidden",
    justification = "Absolute env cannot be used to bypass infrastructure destruction guardrails.",
    match = [
        "/usr/bin/env terraform destroy",
    ],
    not_match = [
        "/usr/bin/env terraform plan",
    ],
)

prefix_rule(
    pattern = ["/usr/bin/env", "kubectl", "delete"],
    decision = "forbidden",
    justification = "Absolute env cannot be used to bypass Kubernetes deletion guardrails.",
    match = [
        "/usr/bin/env kubectl delete pod api-123",
    ],
    not_match = [
        "/usr/bin/env kubectl get pods",
    ],
)

prefix_rule(
    pattern = ["env", "terraform", "destroy"],
    decision = "forbidden",
    justification = "Wrapper-prefixed infrastructure destruction must use an explicit operator workflow.",
    match = [
        "env terraform destroy",
    ],
    not_match = [
        "env terraform plan",
    ],
)

prefix_rule(
    pattern = ["env", "kubectl", "delete"],
    decision = "forbidden",
    justification = "Wrapper-prefixed Kubernetes deletion must use an explicit operator workflow.",
    match = [
        "env kubectl delete pod api-123",
    ],
    not_match = [
        "env kubectl get pods",
    ],
)

prefix_rule(
    pattern = ["bash", ["-c", "-lc"]],
    decision = "forbidden",
    justification = "Shell command wrappers can hide destructive operations from prefix rules. Run the command directly so policy can inspect the prefix.",
    match = [
        "bash -lc 'rm -rf build'",
        "bash -c 'kubectl delete namespace prod'",
    ],
    not_match = [
        "bash --version",
    ],
)

prefix_rule(
    pattern = ["sh", "-c"],
    decision = "forbidden",
    justification = "Shell command wrappers can hide destructive operations from prefix rules. Run the command directly so policy can inspect the prefix.",
    match = [
        "sh -c 'git reset --hard'",
    ],
    not_match = [
        "sh --version",
    ],
)

prefix_rule(
    pattern = ["zsh", ["-c", "-lc"]],
    decision = "forbidden",
    justification = "Shell command wrappers can hide destructive operations from prefix rules. Run the command directly so policy can inspect the prefix.",
    match = [
        "zsh -lc 'terraform destroy'",
    ],
    not_match = [
        "zsh --version",
    ],
)

prefix_rule(
    pattern = [["/bin/bash", "/usr/bin/bash"], ["-c", "-lc"]],
    decision = "forbidden",
    justification = "Absolute shell command wrappers can hide destructive operations from prefix rules. Run the command directly so policy can inspect the prefix.",
    match = [
        "/bin/bash -lc 'rm -rf build'",
        "/usr/bin/bash -c 'kubectl delete namespace prod'",
    ],
    not_match = [
        "/bin/bash --version",
    ],
)

prefix_rule(
    pattern = [["/bin/sh", "/usr/bin/sh"], "-c"],
    decision = "forbidden",
    justification = "Absolute shell command wrappers can hide destructive operations from prefix rules. Run the command directly so policy can inspect the prefix.",
    match = [
        "/bin/sh -c 'git reset --hard'",
        "/usr/bin/sh -c 'terraform destroy'",
    ],
    not_match = [
        "/bin/sh --version",
    ],
)

prefix_rule(
    pattern = [["/bin/zsh", "/usr/bin/zsh"], ["-c", "-lc"]],
    decision = "forbidden",
    justification = "Absolute shell command wrappers can hide destructive operations from prefix rules. Run the command directly so policy can inspect the prefix.",
    match = [
        "/bin/zsh -lc 'terraform destroy'",
        "/usr/bin/zsh -c 'rm -rf build'",
    ],
    not_match = [
        "/bin/zsh --version",
    ],
)

prefix_rule(
    pattern = ["command", "rm", ["-rf", "-fr"]],
    decision = "forbidden",
    justification = "The command builtin cannot be used to bypass recursive force deletion guardrails.",
    match = [
        "command rm -rf build",
        "command rm -fr build",
    ],
    not_match = [
        "command -v codex",
    ],
)

prefix_rule(
    pattern = ["command", "rm", ["-r", "-f", "--recursive", "--force"]],
    decision = "prompt",
    justification = "The command builtin cannot be used to bypass rm recursive/force guardrails.",
    match = [
        "command rm -r -f build",
        "command rm --recursive --force build",
    ],
    not_match = [
        "command -v codex",
    ],
)

prefix_rule(
    pattern = ["command", "git", "reset", "--hard"],
    decision = "forbidden",
    justification = "The command builtin cannot be used to bypass hard reset guardrails.",
    match = [
        "command git reset --hard",
    ],
    not_match = [
        "command git status",
    ],
)

prefix_rule(
    pattern = ["command", "git", "push"],
    decision = "prompt",
    justification = "The command builtin can hide late git push force flags from fixed-prefix rules. Ask for explicit approval before pushing.",
    match = [
        "command git push origin feature",
        "command git push origin feature --force-with-lease",
    ],
    not_match = [
        "git status",
    ],
)

prefix_rule(
    pattern = ["command", "terraform", "destroy"],
    decision = "forbidden",
    justification = "The command builtin cannot be used to bypass infrastructure destruction guardrails.",
    match = [
        "command terraform destroy",
    ],
    not_match = [
        "command terraform plan",
    ],
)

prefix_rule(
    pattern = ["command", "kubectl", "delete"],
    decision = "forbidden",
    justification = "The command builtin cannot be used to bypass Kubernetes deletion guardrails.",
    match = [
        "command kubectl delete namespace prod",
    ],
    not_match = [
        "command kubectl get pods",
    ],
)

prefix_rule(
    pattern = ["command", ["bash", "sh", "zsh", "/bin/bash", "/bin/sh", "/bin/zsh", "/usr/bin/bash", "/usr/bin/sh", "/usr/bin/zsh"]],
    decision = "forbidden",
    justification = "The command builtin cannot be used to bypass shell-wrapper guardrails.",
    match = [
        "command bash -lc 'rm -rf build'",
        "command /bin/bash -lc 'rm -rf build'",
    ],
    not_match = [
        "command -v codex",
    ],
)

prefix_rule(
    pattern = ["command", "-p"],
    decision = "prompt",
    justification = "command -p changes executable lookup and can bypass prefix-specific guardrails. Run the target command directly or ask for explicit approval.",
    match = [
        "command -p rm -rf build",
    ],
    not_match = [
        "command -v codex",
    ],
)

prefix_rule(
    pattern = [["python", "python3", "node", "perl", "ruby"], ["-c", "-e", "--eval"]],
    decision = "forbidden",
    justification = "Interpreter one-liners can hide destructive commands from prefix policy. Use checked-in scripts or direct commands instead.",
    match = [
        "python3 -c 'import shutil; shutil.rmtree(\"build\")'",
        "node -e 'require(\"child_process\").execSync(\"rm -rf build\")'",
    ],
    not_match = [
        "python3 .codex/scripts/verify.py",
        "node --version",
    ],
)

prefix_rule(
    pattern = [["/usr/bin/python3", "/usr/bin/python", "/opt/homebrew/bin/python3"], "-c"],
    decision = "forbidden",
    justification = "Absolute interpreter one-liners can hide destructive commands from prefix policy. Use checked-in scripts or direct commands instead.",
    match = [
        "/usr/bin/python3 -c 'import os'",
        "/opt/homebrew/bin/python3 -c 'import os'",
    ],
    not_match = [
        "/usr/bin/python3 .codex/scripts/verify.py",
    ],
)

prefix_rule(
    pattern = [["/usr/bin/node", "/opt/homebrew/bin/node"], ["-e", "--eval"]],
    decision = "forbidden",
    justification = "Absolute Node one-liners can hide destructive commands from prefix policy. Use checked-in scripts or direct commands instead.",
    match = [
        "/usr/bin/node -e 'console.log(1)'",
        "/opt/homebrew/bin/node --eval 'console.log(1)'",
    ],
    not_match = [
        "/usr/bin/node --version",
    ],
)

prefix_rule(
    pattern = [["/bin/rm", "/usr/bin/rm"], ["-rf", "-fr"]],
    decision = "forbidden",
    justification = "Absolute rm cannot be used to bypass recursive force deletion guardrails.",
    match = [
        "/bin/rm -rf build",
        "/usr/bin/rm -fr build",
    ],
    not_match = [
        "/bin/rm file.txt",
    ],
)

prefix_rule(
    pattern = [["/bin/rm", "/usr/bin/rm"], ["-r", "-f", "--recursive", "--force"]],
    decision = "prompt",
    justification = "Absolute rm recursive/force variants can become destructive when combined. Use a scoped command or ask for explicit approval.",
    match = [
        "/bin/rm -r -f build",
        "/usr/bin/rm --recursive --force build",
    ],
    not_match = [
        "/bin/rm file.txt",
    ],
)

prefix_rule(
    pattern = [["/usr/bin/git", "/opt/homebrew/bin/git"], "reset", "--hard"],
    decision = "forbidden",
    justification = "Absolute git cannot be used to bypass hard reset guardrails.",
    match = [
        "/usr/bin/git reset --hard",
        "/opt/homebrew/bin/git reset --hard",
    ],
    not_match = [
        "/usr/bin/git status",
    ],
)

prefix_rule(
    pattern = [["/usr/bin/git", "/opt/homebrew/bin/git"], "push"],
    decision = "prompt",
    justification = "Absolute git can hide late force flags from fixed-prefix rules. Ask for explicit approval before pushing.",
    match = [
        "/usr/bin/git push origin feature --force-with-lease",
        "/opt/homebrew/bin/git push origin feature",
    ],
    not_match = [
        "/usr/bin/git status",
    ],
)

prefix_rule(
    pattern = [["/usr/bin/terraform", "/opt/homebrew/bin/terraform"], "destroy"],
    decision = "forbidden",
    justification = "Absolute terraform cannot be used to bypass infrastructure destruction guardrails.",
    match = [
        "/usr/bin/terraform destroy",
        "/opt/homebrew/bin/terraform destroy",
    ],
    not_match = [
        "/usr/bin/terraform plan",
    ],
)

prefix_rule(
    pattern = [["/usr/bin/kubectl", "/opt/homebrew/bin/kubectl"], "delete"],
    decision = "forbidden",
    justification = "Absolute kubectl cannot be used to bypass Kubernetes deletion guardrails.",
    match = [
        "/usr/bin/kubectl delete pod api-123",
        "/opt/homebrew/bin/kubectl delete namespace prod",
    ],
    not_match = [
        "/usr/bin/kubectl get pods",
    ],
)

prefix_rule(
    pattern = ["terraform", "destroy"],
    decision = "forbidden",
    justification = "Infrastructure destruction must not run from the agent harness without an explicit operator workflow.",
    match = [
        "terraform destroy",
        "terraform destroy -auto-approve",
    ],
    not_match = [
        "terraform plan",
    ],
)

prefix_rule(
    pattern = ["terraform", "apply"],
    decision = "prompt",
    justification = "Terraform apply can destroy infrastructure when passed destroy flags or plans. Use a reviewed plan and explicit approval.",
    match = [
        "terraform apply -destroy -auto-approve",
        "terraform apply tfplan",
    ],
    not_match = [
        "terraform plan",
    ],
)

prefix_rule(
    pattern = ["kubectl", "delete"],
    decision = "forbidden",
    justification = "Kubernetes deletion must not run from the agent harness without an explicit operator workflow.",
    match = [
        "kubectl delete pod api-123",
        "kubectl delete namespace prod",
    ],
    not_match = [
        "kubectl get pods",
        "kubectl describe pod api-123",
    ],
)

prefix_rule(
    pattern = ["python3", "/Users/ravikiranvemula/.claude/skills/autoreview/scripts/autoreview"],
    decision = "allow",
    justification = "The autoreview helper is the pipeline's review entrypoint; codex runs it as the review wrapper around its own exec engine.",
    match = [
        "python3 /Users/ravikiranvemula/.claude/skills/autoreview/scripts/autoreview --mode branch --base origin/main",
    ],
    not_match = [
        "python3 -c 'import os'",
    ],
)
