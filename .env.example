# Gantry runtime-owned local secrets.
#
# Copy to <GANTRY_HOME>/.env for local/personal mode. Non-secret settings
# belong in <GANTRY_HOME>/settings.yaml, not here. Agent-accessed provider
# credentials such as ANTHROPIC_API_KEY, OPENAI_API_KEY, and
# CLAUDE_CODE_OAUTH_TOKEN must be configured through Gantry Credentials.

# Runtime root for Gantry local state. Default when unset: ~/gantry.
# Local provider artifacts are stored under <GANTRY_HOME>/artifacts/.
# Do not set CLAUDE_CONFIG_DIR here; Gantry creates it per Claude run.
GANTRY_HOME=

# Runtime Postgres database URL. The configured settings.yaml key is
# storage.postgres.url_env, which defaults to GANTRY_DATABASE_URL.
GANTRY_DATABASE_URL=postgres://gantry:change-me@127.0.0.1:5432/gantry?schema=gantry

# Fleet/ECS artifact bootstrap. These are non-secret startup settings used when
# GANTRY_FLEET_SETTINGS_AUTO=1 seeds runtime.artifact_store into settings.yaml.
# In managed deployments, keep the same values in the ECS task definition or
# Terraform source of truth so S3 remains authoritative across redeploys.
GANTRY_FLEET_SETTINGS_AUTO=0
GANTRY_ARTIFACT_BUCKET=
GANTRY_ARTIFACT_REGION=
# AWS_REGION may be used instead of GANTRY_ARTIFACT_REGION when running on AWS.
AWS_REGION=

# Base64-encoded 32-byte key for local Credential Center encryption.
SECRET_ENCRYPTION_KEY=

# Stable IPC signing secret. Generate a high-entropy value for production.
GANTRY_IPC_AUTH_SECRET=

# OTLP backend examples:
# - Langfuse: GANTRY_OTEL_TRACES_HEADERS=Authorization=Basic <base64 pk:sk>
#   endpoint: <base>/api/public/otel/v1/traces
# - LangSmith: GANTRY_OTEL_TRACES_HEADERS=x-api-key=<key>,Langsmith-Project=<project>
#   endpoint: https://api.smith.langchain.com/otel/v1/traces
# GANTRY_OTEL_TRACES_HEADERS=

# Control API for local SDK/CLI/admin automation. Prefer scoped JSON keys for
# anything beyond local development. Keep these process-local; they are runtime
# access secrets, not settings.yaml desired state.
GANTRY_CONTROL_API_KEY=
GANTRY_CONTROL_API_KEYS_JSON=
GANTRY_CONTROL_APP_ID=default
GANTRY_CONTROL_HOST=
GANTRY_CONTROL_PORT=
GANTRY_CONTROL_SOCKET_PATH=
GANTRY_CONTROL_BASE_URL=

# Optional loopback-only Web UI linkage for a workstation runtime. Disabled by
# default and rejected in production, remote, non-loopback, or worker modes.
# The key ID must reference a dedicated entry in GANTRY_CONTROL_API_KEYS_JSON;
# its bearer token stays server-side and is never returned to the browser.
GANTRY_UI_LOCAL_OWNER_ENABLED=false
GANTRY_UI_LOCAL_OWNER_KEY_ID=

# Channel runtime secrets. Fill only for enabled channels.
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Optional runtime-only operational knobs. Most non-secret behavior belongs in
# settings.yaml; use these only for process/startup behavior.
LOG_LEVEL=info
LOG_FORMAT=json
GANTRY_LOG_STDERR=false
REMOTE_CONTROL_AUTO_ACCEPT=false
CHROME_PATH=
TZ=

# Optional trust bundle for managed Postgres or corporate TLS interception.
# Set only when the provider requires a CA file that is not already trusted by
# the host OS/Node runtime.
NODE_EXTRA_CA_CERTS=

# Approval/runtime limits.
PERMISSION_APPROVAL_TIMEOUT_MS=
AGENT_TIMEOUT=
AGENT_MAX_OUTPUT_SIZE=
MAX_MESSAGES_PER_PROMPT=
IDLE_TIMEOUT=

# Startup safety valve. Set to 1 only to recover from a bad authoritative
# settings.yaml/DB drift event; normal startup should reconcile settings.yaml.
GANTRY_SKIP_RECONCILE_ON_STARTUP=

# Control webhook hardening. Leave unset unless local development needs it.
GANTRY_CONTROL_WEBHOOK_ALLOWED_HOSTS=
GANTRY_CONTROL_ALLOW_PRIVATE_WEBHOOKS=false
GANTRY_CONTROL_ALLOW_INSECURE_WEBHOOKS=false

# Memory tuning. Model/provider choices belong in settings.yaml; these are
# process-level limits and schedules.
MEMORY_DREAMING_CRON=
MEMORY_EMBED_BATCH_SIZE=
MEMORY_MAINTENANCE_MAX_PENDING=
OPENAI_DAILY_EMBED_LIMIT=
MEMORY_EXTRACTOR_MAX_FACTS=
MEMORY_EXTRACTOR_MIN_CONFIDENCE=

# Do not add ANTHROPIC_API_KEY, ANTHROPIC_AUTH_TOKEN, OPENAI_API_KEY,
# CLAUDE_CODE_OAUTH_TOKEN, ANTHROPIC_MODEL, or ANTHROPIC_BASE_URL here.
# Model/provider credentials and SDK env are resolved by Gantry Model Gateway
# and generated internally for child agent processes.
