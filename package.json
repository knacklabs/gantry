{
  "name": "@myclaw/core",
  "version": "1.2.52",
  "description": "Personal AI assistant runtime. Lightweight, secure, customizable.",
  "author": "MyClaw Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vrknetha/myclaw.git"
  },
  "homepage": "https://github.com/vrknetha/myclaw",
  "bugs": {
    "url": "https://github.com/vrknetha/myclaw/issues"
  },
  "keywords": [
    "assistant",
    "agent",
    "runtime",
    "cli",
    "automation"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "myclaw": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "packages/contracts/dist/",
    "packages/contracts/package.json",
    "!**/*.map",
    ".claude/skills/*/SKILL.md"
  ],
  "workspaces": [
    "packages/contracts"
  ],
  "scripts": {
    "build:contracts": "npm run build --workspace @myclaw/contracts",
    "clean": "rm -rf dist packages/contracts/dist",
    "build": "npm run clean && npm run build:contracts && tsc",
    "start": "node dist/index.js",
    "dev": "tsx apps/core/src/index.ts",
    "cli:dev": "tsx apps/core/src/cli/index.ts",
    "typecheck": "npm run typecheck --workspace @myclaw/contracts && tsc --noEmit",
    "format": "prettier --write \"apps/core/**/*.{ts,md}\" \"packages/contracts/src/**/*.ts\"",
    "format:fix": "prettier --write \"apps/core/**/*.{ts,md}\" \"packages/contracts/src/**/*.ts\"",
    "format:check": "prettier --check \"apps/core/**/*.{ts,md}\" \"packages/contracts/src/**/*.ts\"",
    "prepare": "HUSKY=1 husky || true",
    "prepublishOnly": "npm run build",
    "lint": "eslint apps/core/src packages/contracts/src",
    "lint:fix": "eslint apps/core/src packages/contracts/src --fix",
    "test": "npm run build:contracts && npm run test:unit && npm run test:integration",
    "test:unit": "npm run build:contracts && vitest run -c vitest.unit.config.ts",
    "test:integration": "npm run build:contracts && vitest run -c vitest.integration.config.ts",
    "test:e2e": "npm run build:contracts && vitest run -c vitest.e2e.config.ts",
    "test:watch": "npm run build:contracts && vitest -c vitest.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.112",
    "@anthropic-ai/sdk": "^0.90.0",
    "@clack/prompts": "^1.2.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/stream": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@myclaw/contracts": "file:packages/contracts",
    "@onecli-sh/sdk": "^0.2.0",
    "@slack/bolt": "^4.7.0",
    "better-sqlite3": "11.10.0",
    "cron-parser": "5.5.0",
    "grammy": "^1.42.0",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
