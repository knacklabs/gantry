{
  "name": "@gantry/sdk",
  "version": "0.4.0",
  "description": "Node.js SDK for the Gantry runtime control API: sessions, jobs, agents, memory, webhooks, and ingress signing.",
  "author": "Gantry Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gantry/gantry.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/gantry/gantry/tree/main/packages/sdk",
  "bugs": {
    "url": "https://github.com/gantry/gantry/issues"
  },
  "keywords": [
    "gantry",
    "sdk",
    "client",
    "agent",
    "ai",
    "automation"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=24 <26"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  }
}
