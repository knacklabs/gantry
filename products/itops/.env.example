# IT Ops API
NODE_ENV=development
ITOPS_API_HOST=127.0.0.1
ITOPS_API_PORT=4000

# Runtime database connection used by the API and worker.
# Use the Supabase Session Pooler connection string.
ITOPS_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Migration database connection used by Drizzle Kit.
# Use the Supabase Direct connection string only when your network supports IPv6
# or your project has the Supabase IPv4 add-on. Otherwise use the Session Pooler.
ITOPS_MIGRATION_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Gantry control API - only needed when backend starts workflows programmatically
GANTRY_CONTROL_URL=http://127.0.0.1:8787
GANTRY_API_KEY=

# Gantry native IT Ops tools call the API directly. There is no IT Ops MCP
# bridge, MCP URL, or MCP bearer token in this deployment.
ITOPS_API_BASE_URL=http://127.0.0.1:4000
ITOPS_API_TIMEOUT_MS=15000
# Access-task execution retries only; useful for slow browser invite flows.
ITOPS_API_RETRY_ATTEMPTS=2
ITOPS_API_RETRY_DELAY_MS=3000
ITOPS_API_KEY=

# Approval policy
ITOPS_APPROVAL_POLICY_ENABLED=true
# Comma-separated Slack/Gantry external user ids. Raw Slack ids like U123 are also accepted.
ITOPS_APPROVER_EXTERNAL_USER_IDS=slack:U1234567890,slack:U0987654321
ITOPS_ALLOW_SELF_APPROVAL=false

# External connectors - keep disabled/empty unless the matching connector is enabled.
# Google credentials are required only when GOOGLE_WORKSPACE_ENABLED=true.
GOOGLE_WORKSPACE_ENABLED=false
GOOGLE_WORKSPACE_DOMAIN=
GOOGLE_WORKSPACE_ADMIN_EMAIL=
GOOGLE_WORKSPACE_CLIENT_EMAIL=
GOOGLE_WORKSPACE_PRIVATE_KEY=

# Gmail welcome email sender. If any value is missing, welcome email sending is skipped.
EMAIL_ITOPS_FROM=itops@caw.tech
GMAIL_CLIENT_EMAIL=
GMAIL_PRIVATE_KEY=
GMAIL_IMPERSONATED_ITOPS_EMAIL=itops@caw.tech

# Slack channel membership connector.
# SLACK_BOT_TOKEN is the Bot User OAuth Token, usually xoxb-...
# Allowed values: mock, real.
# Required only when SLACK_CHANNEL_CONNECTOR_MODE=real.
SLACK_CHANNEL_CONNECTOR_MODE=mock
SLACK_BOT_TOKEN=

# Slack workspace invite connector.
# Allowed values: manual, automated, browser.
# Manual is the default and requires no Slack invite config.
# automated preserves the Slack Admin API admin.users.invite connector and is Enterprise-only.
# browser is opt-in/config-gated; browser automation is dry-run by default.
SLACK_WORKSPACE_INVITE_MODE=manual
# SLACK_ADMIN_TOKEN is a User OAuth Token, usually xoxp-..., with admin.users:write.
# SLACK_TEAM_ID is the workspace id, usually T..., from URLs like /client/T.../C...
# SLACK_DEFAULT_INVITE_CHANNEL_IDS is a comma-separated list of channel ids, not names.
SLACK_ADMIN_TOKEN=
SLACK_TEAM_ID=
SLACK_DEFAULT_INVITE_CHANNEL_IDS=
# Browser invite mode. Login mode manual opens a browser for interactive setup.
# Login mode google_sso automates Slack -> Google -> Microsoft redirect using the same email/password.
# Never log browser passwords, cookies, localStorage, or session data.
SLACK_BROWSER_WORKSPACE_URL=
SLACK_BROWSER_PROFILE_DIR=
SLACK_BROWSER_HEADLESS=true
SLACK_BROWSER_DRY_RUN=true
SLACK_BROWSER_INVITE_TIMEOUT_MS=30000
# Allowed values: manual, google_sso.
SLACK_BROWSER_LOGIN_MODE=manual
SLACK_BROWSER_LOGIN_EMAIL=
SLACK_BROWSER_LOGIN_PASSWORD=

GITHUB_TOKEN=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

AWS_REGION=
CODEX_ADMIN_API_KEY=
