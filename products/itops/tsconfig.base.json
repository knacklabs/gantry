{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@itops/config": ["packages/config/src/index.ts"],
      "@itops/contracts": ["packages/contracts/src/index.ts"],
      "@itops/connectors": ["packages/connectors/src/index.ts"],
      "@itops/db": ["packages/db/src/index.ts"],
      "@itops/logger": ["packages/logger/src/index.ts"]
    }
  }
}
